    "start": "bun --env-file=../../.env src/index.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@habit-gamba/db": "workspace:*",
    "@habit-gamba/env": "workspace:*",
    "hono": "^4.10.7"
  }
}
