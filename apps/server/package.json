{
  "name": "@habit-gamba/server",
  "type": "module",
  "scripts": {
    "build": "bun run check-types",
    "check-types": "tsc --noEmit",
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "lint": "oxlint .",
    "start": "bun --env-file=../../.env src/index.ts",
    "test": "bun --env-file=../../.env vitest run --passWithNoTests"
  },
  "dependencies": {
    "@habit-gamba/api": "workspace:*",
    "@habit-gamba/contracts": "workspace:*",
    "@habit-gamba/db": "workspace:*",
    "@habit-gamba/env": "workspace:*",
    "@habit-gamba/exchange": "workspace:*",
    "@habit-gamba/resolution": "workspace:*",
    "@habit-gamba/users": "workspace:*",
    "@habit-gamba/wallet": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.7",
    "zod": "^4.1.13"
  }
}
