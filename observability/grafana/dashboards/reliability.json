{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (path, status_code) (rate(habit_gamba_http_requests_total[5m]))",
          "legendFormat": "{{path}} {{status_code}}"
        }
      ],
      "title": "HTTP Requests",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(habit_gamba_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ],
      "title": "HTTP p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (command, outcome) (rate(habit_gamba_discord_interactions_total[5m]))",
          "legendFormat": "{{command}} {{outcome}}"
        }
      ],
      "title": "Discord Interactions",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (outcome) (rate(habit_gamba_market_lifecycle_worker_runs_total[15m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "title": "Lifecycle Worker Runs",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "{container=~\".*\"} | json | level=\"error\"",
          "refId": "A"
        }
      ],
      "title": "Recent Error Logs",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": ["habit-gamba", "reliability"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
